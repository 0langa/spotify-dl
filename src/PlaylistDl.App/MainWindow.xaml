<Window x:Class="PlaylistDl.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Playlist DL" Height="760" Width="1180" MinHeight="620" MinWidth="860"
        WindowStartupLocation="CenterScreen">
  <Grid Background="#111318">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#181B22" Padding="24,18">
      <DockPanel LastChildFill="False">
        <StackPanel DockPanel.Dock="Left">
          <TextBlock Text="Playlist DL" FontSize="26" FontWeight="SemiBold" Foreground="White" />
          <TextBlock Text="Personal playlist, album, and track matching and audio download" Foreground="#AEB6C5" Margin="0,3,0,0" />
        </StackPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
          <Button x:Name="UpdateButton" Content="Check for updates" Margin="0,0,10,0"
                  Click="UpdateButton_Click" />
          <Button x:Name="ResumeButton" Content="Resume last job" Visibility="Collapsed"
                  Margin="0,0,10,0" Click="ResumeButton_Click" />
          <Button Content="Library" Width="90" Margin="0,0,10,0" Click="LibraryButton_Click" />
          <Button Content="Settings" Width="100" Click="SettingsButton_Click" />
        </StackPanel>
      </DockPanel>
    </Border>

    <Border Grid.Row="1" Margin="24,20,24,12" Background="#1B1F27" CornerRadius="10" Padding="18">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBox x:Name="PlaylistUrlBox" Grid.Row="0" Grid.Column="0" Margin="0,0,10,0"
                 VerticalContentAlignment="Center"
                 ToolTip="Paste a public Spotify playlist, album, or track URL"
                 Text="" />
        <Button Grid.Row="0" Grid.Column="1" Content="Import CSV/JSON" Margin="0,0,10,0"
                Click="ImportManifestButton_Click" />
        <Button x:Name="AnalyzeButton" Grid.Row="0" Grid.Column="2" Content="Analyze link"
                Click="AnalyzeButton_Click" Background="#4F7DFF" Foreground="White" />
        <Grid Grid.Row="1" Grid.ColumnSpan="3" Margin="0,12,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBlock Text="Output" Foreground="#AEB6C5" VerticalAlignment="Center" Margin="0,0,10,0" />
          <TextBox x:Name="OutputDirectoryBox" Grid.Column="1" Text="" IsReadOnly="True" />
          <Button Grid.Column="2" Content="Choose folder" Margin="10,0,0,0" Click="ChooseFolderButton_Click" />
          <Button Grid.Column="3" Content="Open folder" Margin="10,0,0,0" Click="OpenFolderButton_Click" />
        </Grid>
      </Grid>
    </Border>

    <Grid Grid.Row="2" Margin="24,0,24,12">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <DockPanel Margin="2,0,2,10">
        <TextBlock x:Name="PlaylistTitle" Text="Paste a Spotify link to begin" FontSize="19" FontWeight="SemiBold" Foreground="White" />
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
          <TextBlock x:Name="PlaylistSummary" Foreground="#AEB6C5" VerticalAlignment="Center" Margin="0,0,16,0" />
          <TextBox x:Name="FilterBox" Width="220" VerticalContentAlignment="Center"
                   ToolTip="Filter by title, artist, or album" TextChanged="FilterBox_TextChanged" />
          <CheckBox x:Name="SelectAllBox" Content="Select all" IsChecked="True" Margin="14,0,0,0"
                    VerticalAlignment="Center" Foreground="#AEB6C5"
                    Checked="SelectAllBox_Toggled" Unchecked="SelectAllBox_Toggled" />
        </StackPanel>
      </DockPanel>
      <DataGrid Grid.Row="1" x:Name="TrackGrid" ItemsSource="{Binding Tracks}" AutoGenerateColumns="False"
                IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column"
                RowHeaderWidth="0" GridLinesVisibility="Horizontal" AlternatingRowBackground="#151820"
                Background="#111318" Foreground="#E7EBF2" BorderBrush="#303642"
                EnableRowVirtualization="True">
        <DataGrid.Columns>
          <DataGridTemplateColumn Width="36">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                          HorizontalAlignment="Center" VerticalAlignment="Center" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn Header="#" Binding="{Binding Position}" Width="48" />
          <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="2*" />
          <DataGridTextColumn Header="Artist" Binding="{Binding ArtistText}" Width="1.5*" />
          <DataGridTextColumn Header="Album" Binding="{Binding Album}" Width="1.5*" />
          <DataGridTextColumn Header="Length" Binding="{Binding DurationText}" Width="70" />
          <DataGridTemplateColumn Header="Source" Width="84">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <Button Content="{Binding SourceLabel}" Padding="6,2" Click="SourceButton_Click"
                        ToolTip="Choose an exact YouTube source for this track" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTemplateColumn Header="Progress" Width="160">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <Grid Margin="4" ToolTip="{Binding ErrorText}" ToolTipService.IsEnabled="{Binding HasError}">
                  <ProgressBar Value="{Binding Progress}" Maximum="100" Height="16" />
                  <TextBlock Text="{Binding Status}" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Grid>

    <Border x:Name="FailureBanner" Grid.Row="3" Background="#3A2A16" BorderBrush="#8A6A2F"
            BorderThickness="0,1,0,1" Padding="24,10" Visibility="Collapsed">
      <DockPanel LastChildFill="True">
        <Button DockPanel.Dock="Right" Content="Open settings" Margin="10,0,0,0"
                VerticalAlignment="Center" Click="SettingsButton_Click" />
        <Button x:Name="DiagnoseButton" DockPanel.Dock="Right" Content="Diagnose network"
                Margin="10,0,0,0" VerticalAlignment="Center" Click="DiagnoseButton_Click" />
        <TextBlock x:Name="FailureBannerText" Foreground="#F0D9A6" TextWrapping="Wrap"
                   VerticalAlignment="Center" />
      </DockPanel>
    </Border>

    <Border Grid.Row="4" Background="#181B22" Padding="24,14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock x:Name="StatusText" Text="Ready" Foreground="White" />
          <ProgressBar x:Name="OverallProgress" Height="5" Margin="0,8,20,0" Maximum="100" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,14,0" VerticalAlignment="Center">
          <TextBlock Text="Format" Foreground="#AEB6C5" VerticalAlignment="Center" Margin="0,0,8,0" />
          <ComboBox x:Name="QuickFormatBox" Width="90" Height="30" SelectionChanged="QuickFormatBox_SelectionChanged">
            <ComboBoxItem Tag="mp3">MP3</ComboBoxItem>
            <ComboBoxItem Tag="m4a">M4A</ComboBoxItem>
            <ComboBoxItem Tag="opus">Opus</ComboBoxItem>
            <ComboBoxItem Tag="flac">FLAC</ComboBoxItem>
            <ComboBoxItem Tag="ogg">OGG</ComboBoxItem>
            <ComboBoxItem Tag="wav">WAV</ComboBoxItem>
          </ComboBox>
        </StackPanel>
        <Button Grid.Column="2" x:Name="RetryFailedButton" Content="Retry failed" Visibility="Collapsed"
                Margin="0,0,10,0" Click="RetryFailedButton_Click" />
        <Button Grid.Column="3" x:Name="CancelButton" Content="Cancel" IsEnabled="False" Margin="0,0,10,0" Click="CancelButton_Click" />
        <Button Grid.Column="4" x:Name="DownloadButton" Content="Download audio" IsEnabled="False"
                Background="#4F7DFF" Foreground="White" Click="DownloadButton_Click" />
      </Grid>
    </Border>
  </Grid>
</Window>
