<Window x:Class="PlaylistDl.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Playlist DL settings" Height="740" Width="650" MinHeight="560"
        WindowStartupLocation="CenterOwner" Background="#111318" Foreground="White">
  <DockPanel Margin="28">
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
      <Button Content="Cancel" Width="90" Margin="0,0,8,0" IsCancel="True" />
      <Button Content="Save" Width="90" Background="#4F7DFF" Foreground="White" IsDefault="True" Click="SaveButton_Click" />
    </StackPanel>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <StackPanel Margin="0,0,12,0">
        <TextBlock Text="Download settings" FontSize="24" FontWeight="SemiBold" />

        <TextBlock Text="Audio format" FontWeight="SemiBold" Margin="0,24,0,0" />
        <ComboBox x:Name="FormatBox" Margin="0,7,0,0" Height="36" SelectedIndex="0" SelectionChanged="FormatBox_SelectionChanged">
          <ComboBoxItem Tag="mp3">MP3 (recommended, plays everywhere)</ComboBoxItem>
          <ComboBoxItem Tag="m4a">M4A / AAC (keeps source stream, no re-encode)</ComboBoxItem>
          <ComboBoxItem Tag="opus">Opus (keeps source stream, no re-encode)</ComboBoxItem>
          <ComboBoxItem Tag="flac">FLAC (lossless container, source stays lossy)</ComboBoxItem>
          <ComboBoxItem Tag="ogg">OGG Vorbis</ComboBoxItem>
          <ComboBoxItem Tag="wav">WAV (uncompressed, large files)</ComboBoxItem>
        </ComboBox>

        <TextBlock Text="MP3 quality" FontWeight="SemiBold" Margin="0,20,0,0" />
        <ComboBox x:Name="BitrateBox" Margin="0,7,0,0" Height="36" SelectedIndex="0">
          <ComboBoxItem Tag="0">V0 variable bitrate (recommended)</ComboBoxItem>
          <ComboBoxItem Tag="320k">320 kbps constant bitrate</ComboBoxItem>
        </ComboBox>
        <TextBlock Text="Source audio usually tops out near 128 kbps, or 256 kbps with YouTube Music Premium. Re-encoding cannot add quality."
                   Foreground="#AEB6C5" TextWrapping="Wrap" Margin="0,6,0,0" />

        <TextBlock Text="Concurrent downloads" FontWeight="SemiBold" Margin="0,20,0,0" />
        <ComboBox x:Name="ThreadsBox" Margin="0,7,0,0" Height="36" SelectedIndex="1">
          <ComboBoxItem Tag="1">1</ComboBoxItem>
          <ComboBoxItem Tag="2">2 (recommended)</ComboBoxItem>
          <ComboBoxItem Tag="3">3</ComboBoxItem>
          <ComboBoxItem Tag="4">4</ComboBoxItem>
        </ComboBox>

        <TextBlock Text="YouTube cookies (optional)" FontWeight="SemiBold" Margin="0,20,0,0" />
        <Grid Margin="0,7,0,0">
          <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
          <TextBox x:Name="CookieFileBox" IsReadOnly="True" />
          <Button Grid.Column="1" Content="Choose file" Margin="8,0,0,0" Click="ChooseCookieButton_Click" />
          <Button Grid.Column="2" Content="Clear" Margin="8,0,0,0" Click="ClearCookieButton_Click" />
        </Grid>
        <TextBlock Text="Only path is saved. Cookie contents stay in selected file and are never logged."
                   Foreground="#AEB6C5" Margin="0,6,0,0" />

        <TextBlock Text="Alternate backend executable (optional)" FontWeight="SemiBold" Margin="0,20,0,0" />
        <Grid Margin="0,7,0,0">
          <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
          <TextBox x:Name="BackendExecutableBox" ToolTip="Paste a full path or use Choose file" />
          <Button Grid.Column="1" Content="Choose file" Margin="8,0,0,0" Click="ChooseBackendButton_Click" />
          <Button Grid.Column="2" Content="Use bundled" Margin="8,0,0,0" Click="ClearBackendButton_Click" />
        </Grid>
        <TextBlock Text="Use when antivirus or VPN software blocks the bundled backend path. Changes activate immediately after Save."
                   Foreground="#AEB6C5" TextWrapping="Wrap" Margin="0,6,0,0" />

        <TextBlock Text="File organization" FontWeight="SemiBold" Margin="0,20,0,0" />
        <ComboBox x:Name="NamingPresetBox" Margin="0,7,0,0" Height="36" SelectedIndex="0">
          <ComboBoxItem Tag="position_artist_title">01 - Artist - Title</ComboBoxItem>
          <ComboBoxItem Tag="artist_title">Artist - Title</ComboBoxItem>
          <ComboBoxItem Tag="album_track_title">Album Artist / Album / 01 - Title</ComboBoxItem>
        </ComboBox>
        <CheckBox x:Name="CreateSourceFolderBox" Content="Create a folder named after the playlist, album, or import"
                  Foreground="White" Margin="0,10,0,0" />

        <TextBlock Text="Download pacing" FontWeight="SemiBold" Margin="0,20,0,0" />
        <ComboBox x:Name="ThrottleBox" Margin="0,7,0,0" Height="36" SelectedIndex="0">
          <ComboBoxItem Tag="0">No delay between batches (default)</ComboBoxItem>
          <ComboBoxItem Tag="1">1 second between batches</ComboBoxItem>
          <ComboBoxItem Tag="2">2 seconds between batches</ComboBoxItem>
          <ComboBoxItem Tag="5">5 seconds between batches</ComboBoxItem>
        </ComboBox>
        <TextBlock Text="A small delay lowers the chance of YouTube rate-limiting large playlists."
                   Foreground="#AEB6C5" TextWrapping="Wrap" Margin="0,6,0,0" />
        <TextBlock Text="Advanced yt-dlp arguments (optional)" FontWeight="SemiBold" Margin="0,14,0,0" />
        <TextBox x:Name="YtDlpArgsBox" Margin="0,7,0,0" Height="32" VerticalContentAlignment="Center"
                 ToolTip="Extra yt-dlp command-line arguments, e.g. --extractor-args youtube:player_client=tv" />
        <TextBlock Text="Passed straight to yt-dlp for advanced unblocking. Leave empty unless needed."
                   Foreground="#AEB6C5" TextWrapping="Wrap" Margin="0,6,0,0" />

        <CheckBox x:Name="WriteM3uBox" Content="Create .m3u8 playlist file after download" Foreground="White" Margin="0,20,0,0" />
        <TextBlock Text="Writes an ordered playlist file next to downloaded tracks."
                   Foreground="#AEB6C5" TextWrapping="Wrap" Margin="0,6,0,0" />
        <CheckBox x:Name="EmbedLyricsBox" Content="Embed lyrics into downloaded files when available" Foreground="White" Margin="0,12,0,0" />
        <TextBlock Text="Fetches lyrics from public providers and stores them in audio tags."
                   Foreground="#AEB6C5" TextWrapping="Wrap" Margin="0,6,0,0" />
        <CheckBox x:Name="AutoUpdateCheckBox" Content="Check for updates on startup (once a day)" Foreground="White" Margin="0,12,0,8" />
      </StackPanel>
    </ScrollViewer>
  </DockPanel>
</Window>
