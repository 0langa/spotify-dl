<Window x:Class="PlaylistDl.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Playlist DL settings" Height="745" Width="600"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="#111318" Foreground="White">
  <Grid Margin="28">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <TextBlock Text="Download settings" FontSize="24" FontWeight="SemiBold" />

    <StackPanel Grid.Row="1" Margin="0,24,0,0">
      <TextBlock Text="Audio format" FontWeight="SemiBold" />
      <ComboBox x:Name="FormatBox" Margin="0,7,0,0" Height="36" SelectedIndex="0" SelectionChanged="FormatBox_SelectionChanged">
        <ComboBoxItem Tag="mp3">MP3 (recommended, plays everywhere)</ComboBoxItem>
        <ComboBoxItem Tag="m4a">M4A / AAC (keeps source stream, no re-encode)</ComboBoxItem>
        <ComboBoxItem Tag="opus">Opus (keeps source stream, no re-encode)</ComboBoxItem>
        <ComboBoxItem Tag="flac">FLAC (lossless container, source stays lossy)</ComboBoxItem>
        <ComboBoxItem Tag="ogg">OGG Vorbis</ComboBoxItem>
        <ComboBoxItem Tag="wav">WAV (uncompressed, large files)</ComboBoxItem>
      </ComboBox>
    </StackPanel>

    <StackPanel Grid.Row="2" Margin="0,20,0,0">
      <TextBlock Text="MP3 quality" FontWeight="SemiBold" />
      <ComboBox x:Name="BitrateBox" Margin="0,7,0,0" Height="36" SelectedIndex="0">
        <ComboBoxItem Tag="0">V0 variable bitrate (recommended)</ComboBoxItem>
        <ComboBoxItem Tag="320k">320 kbps constant bitrate</ComboBoxItem>
      </ComboBox>
      <TextBlock Text="Source audio usually tops out near 128 kbps, or 256 kbps with YouTube Music Premium. Re-encoding cannot add quality."
                 Foreground="#AEB6C5" TextWrapping="Wrap" Margin="0,6,0,0" />
    </StackPanel>

    <StackPanel Grid.Row="3" Margin="0,20,0,0">
      <TextBlock Text="Concurrent downloads" FontWeight="SemiBold" />
      <ComboBox x:Name="ThreadsBox" Margin="0,7,0,0" Height="36" SelectedIndex="1">
        <ComboBoxItem Tag="1">1</ComboBoxItem>
        <ComboBoxItem Tag="2">2 (recommended)</ComboBoxItem>
        <ComboBoxItem Tag="3">3</ComboBoxItem>
        <ComboBoxItem Tag="4">4</ComboBoxItem>
      </ComboBox>
    </StackPanel>

    <StackPanel Grid.Row="4" Margin="0,20,0,0">
      <TextBlock Text="YouTube cookies (optional)" FontWeight="SemiBold" />
      <Grid Margin="0,7,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBox x:Name="CookieFileBox" IsReadOnly="True" />
        <Button Grid.Column="1" Content="Choose file" Margin="8,0,0,0" Click="ChooseCookieButton_Click" />
        <Button Grid.Column="2" Content="Clear" Margin="8,0,0,0" Click="ClearCookieButton_Click" />
      </Grid>
      <TextBlock Text="Only path is saved. Cookie contents stay in selected file and are never logged."
                 Foreground="#AEB6C5" Margin="0,6,0,0" />
    </StackPanel>

    <StackPanel Grid.Row="5" Margin="0,20,0,0">
      <TextBlock Text="File organization" FontWeight="SemiBold" />
      <ComboBox x:Name="NamingPresetBox" Margin="0,7,0,0" Height="36" SelectedIndex="0">
        <ComboBoxItem Tag="position_artist_title">01 - Artist - Title</ComboBoxItem>
        <ComboBoxItem Tag="artist_title">Artist - Title</ComboBoxItem>
        <ComboBoxItem Tag="album_track_title">Album Artist / Album / 01 - Title</ComboBoxItem>
      </ComboBox>
      <CheckBox x:Name="CreateSourceFolderBox" Content="Create a folder named after the playlist, album, or import"
                Foreground="White" Margin="0,10,0,0" />
    </StackPanel>

    <StackPanel Grid.Row="6" Margin="0,20,0,0" VerticalAlignment="Top">
      <CheckBox x:Name="WriteM3uBox" Content="Create .m3u8 playlist file after download" Foreground="White" />
      <TextBlock Text="Writes an ordered playlist file next to the downloaded tracks so players keep the original order."
                 Foreground="#AEB6C5" TextWrapping="Wrap" Margin="0,6,0,0" />
    </StackPanel>

    <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Content="Cancel" Width="90" Margin="0,0,8,0" IsCancel="True" />
      <Button Content="Save" Width="90" Background="#4F7DFF" Foreground="White" IsDefault="True" Click="SaveButton_Click" />
    </StackPanel>
  </Grid>
</Window>
