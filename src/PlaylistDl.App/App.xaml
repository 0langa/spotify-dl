<Application x:Class="PlaylistDl.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <Style TargetType="Button">
      <Setter Property="Padding" Value="14,7" />
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Background" Value="#2A303B" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="#414958" />
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="Padding" Value="10,7" />
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Background" Value="#242933" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="CaretBrush" Value="White" />
      <Setter Property="BorderBrush" Value="#414958" />
      <Setter Property="SelectionBrush" Value="#4F7DFF" />
    </Style>
    <Style TargetType="DataGridColumnHeader">
      <Setter Property="Background" Value="#242933" />
      <Setter Property="Foreground" Value="#DCE2ED" />
      <Setter Property="BorderBrush" Value="#303642" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style TargetType="DataGridCell">
      <Setter Property="BorderBrush" Value="#252B35" />
      <Setter Property="Padding" Value="8,5" />
      <Setter Property="Foreground" Value="#E7EBF2" />
    </Style>
    <Style TargetType="DataGridRow">
      <Setter Property="Background" Value="#111318" />
      <Setter Property="Foreground" Value="#E7EBF2" />
      <Setter Property="MinHeight" Value="42" />
    </Style>
    <Style TargetType="ProgressBar">
      <Setter Property="Background" Value="#2A303B" />
      <Setter Property="Foreground" Value="#4F7DFF" />
    </Style>
  </Application.Resources>
</Application>
